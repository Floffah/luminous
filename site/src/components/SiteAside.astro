---
import { EarthIcon } from "@lucide/astro";

import cn from "@/lib/cn.ts";

interface Props {
    coverImageUrl?: string;
    class?: string;
}

const { coverImageUrl, class: className } = Astro.props;
const homeUrl = import.meta.env.BASE_URL;
---

<aside
    class:list={cn(
        "relative flex w-full flex-col overflow-hidden rounded-xl bg-card",
        className,
    )}
>
    {
        coverImageUrl && (
            <img
                src={coverImageUrl}
                alt=""
                class="absolute inset-0 size-full object-cover"
            />
        )
    }
    <nav
        aria-label="Site navigation"
        class="heading-inset relative z-10 flex w-fit items-center gap-4 rounded-br-xl bg-background py-2 pr-3"
    >
        <a class="flex items-center gap-2" href={homeUrl}>
            <EarthIcon />
            <span class="font-bold">Luminous</span>
        </a>
    </nav>
</aside>
