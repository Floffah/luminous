---
import DocCard from "@/components/DocCard.astro";
import Footer from "@/components/Footer.astro";
import SiteAside from "@/components/SiteAside.astro";
import Layout from "@/layouts/Layout.astro";

import homepage from "./index.typ";
---

<Layout>
    <div class="flex flex-col gap-5 p-5">
        <div class="flex min-h-screen flex-col gap-5 lg:flex-row">
            <div class="flex flex-1 flex-col gap-5">
                <SiteAside
                    class="h-48"
                    coverImageUrl="https://images.unsplash.com/photo-1780336473595-9e1c3c990ca0"
                />
                <article class="prose prose-sm prose-invert">
                    <Fragment set:html={homepage} />
                </article>
            </div>
            <aside class="flex-1">
                <nav class="grid grid-cols-3 gap-2">
                    <DocCard id="history" class="col-span-3 bg-orange-600/80" />
                    <DocCard
                        id="luminous"
                        class="col-span-3 bg-indigo-400/80"
                    />

                    <DocCard
                        id="places/emergence"
                        class="row-span-3 h-auto bg-indigo-400/80"
                    />
                    <DocCard id="places/haven" class="bg-indigo-400/80" />
                    <DocCard id="places/emergence" class="bg-indigo-400/80" />
                    <DocCard id="places/emergence" class="bg-indigo-400/80" />
                    <DocCard id="places/emergence" class="bg-indigo-400/80" />
                    <DocCard id="places/emergence" class="bg-indigo-400/80" />
                    <DocCard id="places/emergence" class="bg-indigo-400/80" />
                </nav>
            </aside>
        </div>

        <Footer />
    </div>
</Layout>
